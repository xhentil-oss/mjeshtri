{
  "name": "mjeshtri-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mjeshtri marketplace API — Express + MySQL (self-hosted on VPS).",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:schema": "node src/scripts/applySchema.js",
    "db:seed": "node src/scripts/seed.js",
    "db:reset": "node src/scripts/applySchema.js && node src/scripts/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "mysql2": "^3.11.3",
    "nanoid": "^5.0.7"
  }
}
