# --- Server ---
PORT=3001
NODE_ENV=production
# Comma-separated list of allowed origins for CORS (your frontend URL)
CORS_ORIGIN=http://localhost:5173

# --- Database (MySQL / MariaDB) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mjeshtri
DB_PASSWORD=change-me
DB_NAME=mjeshtri

# --- Auth ---
# Generate a long random string, e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- Uploads ---
# Folder on disk where uploaded images are stored (relative to server/ or absolute)
UPLOAD_DIR=uploads
# Public base URL that serves the uploads (e.g. https://api.mjeshtri.al/uploads)
UPLOAD_PUBLIC_URL=http://localhost:3001/uploads
MAX_UPLOAD_MB=5

# --- Seed admin (created by db:seed) ---
SEED_ADMIN_EMAIL=admin@demo.al
SEED_ADMIN_PASSWORD=demo1234
